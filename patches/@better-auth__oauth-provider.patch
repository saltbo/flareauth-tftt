+async function handleDeviceCodeGrant(ctx, opts) {
+	let { client_id, client_secret, device_code } = ctx.body;
+	const authorization = ctx.request?.headers.get("authorization") || null;
+	if (authorization?.startsWith("Basic ")) {
+		const res = basicToClientCredentials(authorization);
+		client_id = res?.client_id;
+		client_secret = res?.client_secret;
+	}
+	if (!client_id) throw new APIError("BAD_REQUEST", {
+		error_description: "client_id is required",
+		error: "invalid_request"
+	});
+	if (!device_code) throw new APIError("BAD_REQUEST", {
+		error_description: "device_code is required",
+		error: "invalid_request"
+	});
+	const deviceCodeRecord = await ctx.context.adapter.findOne({
+		model: "deviceCode",
+		where: [{
+			field: "deviceCode",
+			value: device_code
