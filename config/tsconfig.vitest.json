{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": ["@cloudflare/workers-types", "node", "vite/client", "vitest/globals"],
    "noEmit": true
  },
  "include": [
    "../server/**/*.test.ts",
    "../src/**/*.test.ts",
    "../src/**/*.test.tsx",
    "../shared/**/*.test.ts",
    "../server/http/test-deps.ts",
    "../server/http/routes/management.test-utils.ts",
    "../src/features/console/console.test-utils.tsx",
    "../src/features/console/console.test-fixtures.ts",
    "../src/features/console/console.settings-fixtures.ts"
  ],
  "exclude": ["../server/integration/**"]
}
