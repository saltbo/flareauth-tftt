{
  "openapi": "3.1.0",
  "info": {
    "title": "FlareAuth Management API",
    "version": "1.0.0",
    "description": "Stable Management API contract for FlareAuth v1.0."
  },
  "servers": [
    {
      "url": "/api/management"
    }
  ],
  "security": [
    {
      "adminSession": []
    }
  ],
  "paths": {
    "/users": {
      "get": {
        "tags": ["Users"],
        "summary": "List users",
        "parameters": [
          { "$ref": "#/components/parameters/Limit" },
          { "$ref": "#/components/parameters/Offset" },
          {
            "name": "search",
            "in": "query",
            "schema": { "type": "string", "minLength": 1 }
          },
          {
            "name": "searchField",
            "in": "query",
            "schema": { "type": "string", "enum": ["email", "name"] }
          },
          {
            "name": "role",
            "in": "query",
            "schema": { "type": "string", "minLength": 1 }
          },
          {
            "name": "banned",
            "in": "query",
            "schema": { "type": "boolean" }
          }
        ],
        "responses": {
          "200": {
            "description": "Users returned.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListUsersResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "post": {
        "tags": ["Users"],
        "summary": "Create a user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateUserRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "User created." },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/users/{id}": {
      "parameters": [{ "$ref": "#/components/parameters/Id" }],
      "get": {
        "tags": ["Users"],
        "summary": "Get a user",
        "responses": {
          "200": { "description": "User returned." },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "patch": {
        "tags": ["Users"],
        "summary": "Update a user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateUserRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "User updated." },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      },
      "delete": {
        "tags": ["Users"],
        "summary": "Delete a user",
        "responses": {
          "200": { "description": "User deleted." },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/users/password-reset-requests": {
      "post": {
        "tags": ["Users"],
        "summary": "Create a password reset request for a user email",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PasswordResetRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Password reset request accepted." },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/users/{id}/ban": {
      "parameters": [{ "$ref": "#/components/parameters/Id" }],
      "put": {
        "tags": ["Users"],
        "summary": "Ban a user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BanUserRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "User banned." },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      },
      "delete": {
        "tags": ["Users"],
        "summary": "Remove a user ban",
        "responses": {
          "200": { "description": "User ban removed." },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/users/{id}/linked-accounts": { "$ref": "#/components/pathItems/PaginatedCollection" },
    "/users/{id}/applications": { "$ref": "#/components/pathItems/PaginatedCollection" },
    "/users/{id}/sessions": { "$ref": "#/components/pathItems/PaginatedCollection" },
    "/applications": { "$ref": "#/components/pathItems/CrudCollection" },
    "/applications/{id}": { "$ref": "#/components/pathItems/CrudResource" },
    "/applications/{id}/redirect-uris": { "$ref": "#/components/pathItems/PaginatedMutableCollection" },
    "/applications/{id}/client-secrets": { "$ref": "#/components/pathItems/PaginatedMutableCollection" },
    "/connectors": {
      "get": {
        "tags": ["Connectors"],
        "summary": "List identity provider connectors",
        "parameters": [
          { "$ref": "#/components/parameters/Limit" },
          { "$ref": "#/components/parameters/Offset" }
        ],
        "responses": {
          "200": {
            "description": "Connectors returned.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListConnectorsResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "post": {
        "tags": ["Connectors"],
        "summary": "Create an identity provider connector",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateConnectorRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Connector created.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Connector" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/connectors/{id}": {
      "parameters": [{ "$ref": "#/components/parameters/Id" }],
      "get": {
        "tags": ["Connectors"],
        "summary": "Get an identity provider connector",
        "responses": {
          "200": {
            "description": "Connector returned.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Connector" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "patch": {
        "tags": ["Connectors"],
        "summary": "Update an identity provider connector",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateConnectorRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Connector updated.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Connector" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Connectors"],
        "summary": "Delete an identity provider connector",
        "responses": {
          "204": { "description": "Connector deleted." },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/sign-in-settings": {
      "get": {
        "tags": ["SignInSettings"],
        "summary": "Get sign-in settings",
        "responses": {
          "200": {
            "description": "Sign-in settings returned.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SignInSettings" }
              }
            }
          }
        }
      }
    },
    "/organizations": { "$ref": "#/components/pathItems/CrudCollection" },
    "/organizations/{id}": { "$ref": "#/components/pathItems/CrudResource" },
    "/organizations/{id}/members": { "$ref": "#/components/pathItems/PaginatedMutableCollection" },
    "/organizations/{id}/invitations": { "$ref": "#/components/pathItems/PaginatedMutableCollection" },
    "/roles": { "$ref": "#/components/pathItems/CrudCollection" },
    "/roles/{id}": { "$ref": "#/components/pathItems/CrudResource" },
    "/roles/{id}/permissions": {
      "put": {
        "tags": ["Roles"],
        "summary": "Replace role permissions",
        "responses": {
          "204": { "description": "Role permissions replaced." }
        }
      }
    },
    "/user-role-assignments": { "$ref": "#/components/pathItems/RoleAssignmentCollection" },
    "/application-role-assignments": { "$ref": "#/components/pathItems/RoleAssignmentCollection" },
    "/member-role-assignments": { "$ref": "#/components/pathItems/RoleAssignmentCollection" },
    "/api-resources": { "$ref": "#/components/pathItems/CrudCollection" },
    "/api-resources/{id}": { "$ref": "#/components/pathItems/CrudResource" },
    "/api-resources/{id}/scopes": { "$ref": "#/components/pathItems/PaginatedMutableCollection" },
    "/api-resources/{id}/permissions": { "$ref": "#/components/pathItems/PaginatedMutableCollection" },
    "/security/policy": {
      "get": {
        "tags": ["Security"],
        "summary": "Get deployment security policy",
        "responses": {
          "200": { "description": "Security policy returned." }
        }
      }
    },
    "/security/users/{id}": {
      "get": {
        "tags": ["Security"],
        "summary": "Get a user's security state",
        "parameters": [{ "$ref": "#/components/parameters/Id" }],
        "responses": {
          "200": { "description": "Security state returned." }
        }
      }
    },
    "/security/users/{id}/passkeys": { "$ref": "#/components/pathItems/PaginatedCollection" },
    "/security/users/{id}/passkeys/{passkeyId}": {
      "delete": {
        "tags": ["Security"],
        "summary": "Delete a user's passkey",
        "parameters": [
          { "$ref": "#/components/parameters/Id" },
          {
            "name": "passkeyId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "minLength": 1 }
          }
        ],
        "responses": {
          "200": { "description": "Passkey deleted." },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/security/users/{id}/sessions": {
      "get": {
        "tags": ["Security"],
        "summary": "List a user's sessions",
        "parameters": [
          { "$ref": "#/components/parameters/Id" },
          { "$ref": "#/components/parameters/Limit" },
          { "$ref": "#/components/parameters/Offset" }
        ],
        "responses": {
          "200": { "description": "Sessions returned." },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "delete": {
        "tags": ["Security"],
        "summary": "Revoke all sessions for a user",
        "parameters": [{ "$ref": "#/components/parameters/Id" }],
        "responses": {
          "200": { "description": "User sessions revoked." },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/security/users/{id}/sessions/{sessionId}": {
      "delete": {
        "tags": ["Security"],
        "summary": "Revoke one user session",
        "parameters": [
          { "$ref": "#/components/parameters/Id" },
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "minLength": 1 }
          }
        ],
        "responses": {
          "200": { "description": "User session revoked." },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "adminSession": {
        "type": "apiKey",
        "in": "cookie",
        "name": "better-auth.session_token",
        "description": "Authenticated administrator session."
      }
    },
    "parameters": {
      "Id": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string", "minLength": 1 }
      },
      "Limit": {
        "name": "limit",
        "in": "query",
        "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 50 }
      },
      "Offset": {
        "name": "offset",
        "in": "query",
        "schema": { "type": "integer", "minimum": 0, "default": 0 }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid request.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication is required.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Forbidden": {
        "description": "Admin access is required.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "pathItems": {
      "PaginatedCollection": {
        "get": {
          "parameters": [
            { "$ref": "#/components/parameters/Limit" },
            { "$ref": "#/components/parameters/Offset" }
          ],
          "responses": {
            "200": { "description": "Collection returned." },
            "401": { "$ref": "#/components/responses/Unauthorized" },
            "403": { "$ref": "#/components/responses/Forbidden" }
          }
        }
      },
      "PaginatedMutableCollection": {
        "get": {
          "parameters": [
            { "$ref": "#/components/parameters/Limit" },
            { "$ref": "#/components/parameters/Offset" }
          ],
          "responses": { "200": { "description": "Collection returned." } }
        },
        "post": {
          "responses": {
            "201": { "description": "Resource created." },
            "400": { "$ref": "#/components/responses/BadRequest" }
          }
        }
      },
      "CrudCollection": {
        "get": {
          "parameters": [
            { "$ref": "#/components/parameters/Limit" },
            { "$ref": "#/components/parameters/Offset" }
          ],
          "responses": { "200": { "description": "Collection returned." } }
        },
        "post": {
          "responses": {
            "201": { "description": "Resource created." },
            "400": { "$ref": "#/components/responses/BadRequest" }
          }
        }
      },
      "CrudResource": {
        "get": {
          "parameters": [{ "$ref": "#/components/parameters/Id" }],
          "responses": { "200": { "description": "Resource returned." } }
        },
        "patch": {
          "parameters": [{ "$ref": "#/components/parameters/Id" }],
          "responses": {
            "200": { "description": "Resource updated." },
            "400": { "$ref": "#/components/responses/BadRequest" }
          }
        },
        "delete": {
          "parameters": [{ "$ref": "#/components/parameters/Id" }],
          "responses": {
            "204": { "description": "Resource deleted." },
            "404": { "$ref": "#/components/responses/NotFound" }
          }
        }
      },
      "RoleAssignmentCollection": {
        "post": {
          "tags": ["RoleAssignments"],
          "summary": "Create or replace a role assignment",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RoleAssignmentRequest" }
              }
            }
          },
          "responses": {
            "204": { "description": "Role assignment applied." },
            "400": { "$ref": "#/components/responses/BadRequest" }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "object",
            "required": ["code", "message"],
            "properties": {
              "code": {
                "type": "string",
                "enum": ["bad_request", "unauthorized", "forbidden", "not_found", "internal_error"]
              },
              "message": { "type": "string" },
              "requestId": { "type": "string" }
            }
          }
        }
      },
      "Pagination": {
        "type": "object",
        "required": ["limit", "offset", "total", "hasMore", "nextOffset"],
        "properties": {
          "limit": { "type": "integer", "minimum": 1 },
          "offset": { "type": "integer", "minimum": 0 },
          "total": { "type": "integer", "minimum": 0 },
          "hasMore": { "type": "boolean" },
          "nextOffset": { "type": ["integer", "null"], "minimum": 0 }
        }
      },
      "Connector": {
        "type": "object",
        "required": [
          "id",
          "slug",
          "providerType",
          "providerId",
          "displayName",
          "enabled",
          "clientId",
          "clientSecretBinding",
          "issuer",
          "authorizationEndpoint",
          "tokenEndpoint",
          "userInfoEndpoint",
          "jwksEndpoint",
          "scopes",
          "providerMetadata",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "id": { "type": "string" },
          "slug": { "type": "string" },
          "providerType": { "type": "string", "enum": ["social", "generic_oauth"] },
          "providerId": { "type": "string" },
          "displayName": { "type": "string" },
          "enabled": { "type": "boolean" },
          "clientId": { "type": ["string", "null"] },
          "clientSecretBinding": {
            "type": ["string", "null"],
            "description": "Reference to deployment-managed secret material; never the secret value."
          },
          "issuer": { "type": ["string", "null"], "format": "uri" },
          "authorizationEndpoint": { "type": ["string", "null"], "format": "uri" },
          "tokenEndpoint": { "type": ["string", "null"], "format": "uri" },
          "userInfoEndpoint": { "type": ["string", "null"], "format": "uri" },
          "jwksEndpoint": { "type": ["string", "null"], "format": "uri" },
          "scopes": { "type": "array", "items": { "type": "string" } },
          "providerMetadata": { "type": "object", "additionalProperties": true },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "ListConnectorsResponse": {
        "type": "object",
        "required": ["connectors", "pagination"],
        "properties": {
          "connectors": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Connector" }
          },
          "pagination": { "$ref": "#/components/schemas/Pagination" }
        }
      },
      "CreateConnectorRequest": {
        "type": "object",
        "required": ["providerType", "providerId", "displayName", "clientId", "clientSecretBinding"],
        "description": "Create uses the shared connector contract. Generic OAuth connectors require either issuer or authorizationEndpoint, and require tokenEndpoint when issuer is omitted.",
        "properties": {
          "slug": { "type": "string", "minLength": 3, "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "providerType": { "type": "string", "enum": ["social", "generic_oauth"] },
          "providerId": { "type": "string", "minLength": 1 },
          "displayName": { "type": "string", "minLength": 1 },
          "enabled": { "type": "boolean" },
          "clientId": { "type": "string", "minLength": 1 },
          "clientSecretBinding": {
            "type": "string",
            "minLength": 1,
            "description": "Reference to deployment-managed secret material; never the secret value."
          },
          "issuer": { "type": "string", "format": "uri" },
          "authorizationEndpoint": { "type": "string", "format": "uri" },
          "tokenEndpoint": { "type": "string", "format": "uri" },
          "userInfoEndpoint": { "type": "string", "format": "uri" },
          "jwksEndpoint": { "type": "string", "format": "uri" },
          "scopes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "providerMetadata": { "type": "object", "additionalProperties": true }
        }
      },
      "UpdateConnectorRequest": {
        "type": "object",
        "properties": {
          "slug": { "type": "string", "minLength": 3, "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "displayName": { "type": "string", "minLength": 1 },
          "enabled": { "type": "boolean" },
          "clientId": { "type": ["string", "null"], "minLength": 1 },
          "clientSecretBinding": {
            "type": ["string", "null"],
            "minLength": 1,
            "description": "Reference to deployment-managed secret material; never the secret value."
          },
          "issuer": { "type": ["string", "null"], "format": "uri" },
          "authorizationEndpoint": { "type": ["string", "null"], "format": "uri" },
          "tokenEndpoint": { "type": ["string", "null"], "format": "uri" },
          "userInfoEndpoint": { "type": ["string", "null"], "format": "uri" },
          "jwksEndpoint": { "type": ["string", "null"], "format": "uri" },
          "scopes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "providerMetadata": { "type": "object", "additionalProperties": true }
        }
      },
      "User": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "name": { "type": "string" },
          "role": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } },
              { "type": "null" }
            ]
          },
          "banned": { "type": ["boolean", "null"] },
          "createdAt": { "type": "string" },
          "updatedAt": { "type": "string" }
        },
        "additionalProperties": true
      },
      "ListUsersResponse": {
        "type": "object",
        "required": ["users", "pagination"],
        "properties": {
          "users": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/User" }
          },
          "pagination": { "$ref": "#/components/schemas/Pagination" }
        }
      },
      "CreateUserRequest": {
        "type": "object",
        "required": ["email", "displayName"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "minLength": 8 },
          "displayName": { "type": "string", "minLength": 1 },
          "username": { "type": "string", "minLength": 3, "maxLength": 64 },
          "avatarAssetId": { "type": ["string", "null"] },
          "role": {
            "oneOf": [
              { "type": "string", "minLength": 1 },
              { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 }
            ]
          }
        }
      },
      "UpdateUserRequest": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email" },
          "emailVerified": { "type": "boolean" },
          "displayName": { "type": "string", "minLength": 1 },
          "username": { "type": ["string", "null"], "minLength": 3, "maxLength": 64 },
          "avatarAssetId": { "type": ["string", "null"] },
          "role": {
            "oneOf": [
              { "type": "string", "minLength": 1 },
              { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 }
            ]
          }
        }
      },
      "BanUserRequest": {
        "type": "object",
        "properties": {
          "reason": { "type": "string", "minLength": 1 },
          "expiresInSeconds": { "type": "integer", "minimum": 1 }
        }
      },
      "PasswordResetRequest": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "redirectTo": { "type": "string", "format": "uri" }
        }
      },
      "RoleAssignmentRequest": {
        "type": "object",
        "required": ["roleId", "subjectId"],
        "properties": {
          "roleId": { "type": "string", "minLength": 1 },
          "subjectId": { "type": "string", "minLength": 1 },
          "tokenClaims": { "type": "object" },
          "expiresAt": { "type": ["string", "null"], "format": "date-time" }
        }
      },
      "SignInSettings": {
        "type": "object",
        "required": ["signIn", "defaults", "links"],
        "properties": {
          "signIn": {
            "type": "object",
            "required": [
              "passwordEnabled",
              "signupEnabled",
              "socialLoginEnabled",
              "magicLinkEnabled",
              "emailOtpEnabled",
              "usernameEnabled",
              "identifierFirst"
            ],
            "properties": {
              "passwordEnabled": { "type": "boolean" },
              "signupEnabled": { "type": "boolean" },
              "socialLoginEnabled": { "type": "boolean" },
              "magicLinkEnabled": { "type": "boolean" },
              "emailOtpEnabled": { "type": "boolean" },
              "usernameEnabled": { "type": "boolean" },
              "identifierFirst": { "type": "boolean" }
            }
          },
          "defaults": {
            "type": "object",
            "required": ["applicationId", "redirectUri"],
            "properties": {
              "applicationId": { "type": ["string", "null"] },
              "redirectUri": { "type": ["string", "null"] }
            }
          },
          "links": {
            "type": "object",
            "required": ["termsUri", "privacyUri", "supportEmail"],
            "properties": {
              "termsUri": { "type": ["string", "null"] },
              "privacyUri": { "type": ["string", "null"] },
              "supportEmail": { "type": ["string", "null"] }
            }
          }
        }
      }
    }
  }
}
