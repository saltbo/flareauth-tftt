{
  "name": "flareauth-tftt",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "[ \"$WORKERS_CI\" = \"1\" ] && [ \"$WORKERS_CI_BRANCH\" != \"main\" ] && export CF_WRANGLER_CONFIG=wrangler.preview.toml; vite build",
    "deploy": "npm run db:migrate:remote && npm run build && wrangler deploy",
    "deploy:check": "node scripts/check-cloudflare-config.mjs",
    "deploy:self": "npm run db:migrate:self && npm run build && wrangler deploy --config wrangler.production.toml",
    "deploy:prod": "npm run deploy",
    "bootstrap:admin": "node scripts/bootstrap-admin.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply DB --local",
    "db:migrate:e2e": "wrangler d1 migrations apply flareauth-db-e2e --local --config tests/e2e/wrangler.toml --persist-to tests/e2e/.wrangler/state",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "db:migrate:self": "wrangler d1 migrations apply DB --remote --config wrangler.production.toml",
    "db:migrate:staging": "wrangler d1 migrations apply DB --remote --config wrangler.preview.toml",
    "db:migrate:prod": "npm run db:migrate:remote",
    "routes:generate": "tsr generate",
    "typecheck": "npm run routes:generate && tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.vitest.json && tsc --noEmit -p tsconfig.e2e.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "spec:check": "node scripts/verify-specs.mjs",
    "test:e2e": "npm run spec:check && node scripts/run-cucumber-e2e.mjs",
    "test:e2e:report": "npm run test:e2e",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@better-auth/agent-auth": "0.5.1",
    "@better-auth/i18n": "^1.6.11",
    "@better-auth/oauth-provider": "^1.6.10",
    "@better-auth/passkey": "^1.6.10",
    "@fontsource-variable/geist": "^5.2.8",
    "@hono/zod-openapi": "^1.4.0",
    "@hono/zod-validator": "^0.8.0",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "^1.93.0",
    "better-auth": "^1.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "i18next": "^26.1.0",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.7",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.48.11",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@cloudflare/vite-plugin": "^1.36.3",
    "@cloudflare/vitest-pool-workers": "^0.16.3",
    "@cloudflare/workers-types": "^4.20260510.1",
    "@cucumber/cucumber": "^12.9.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-cli": "^1.167.5",
    "@tanstack/router-plugin": "^1.168.6",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^17.0.4",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.2",
    "wrangler": "^4.90.0"
  },
  "cloudflare": {
    "bindings": {
      "BETTER_AUTH_SECRET": {
        "description": "Signing secret for auth sessions. Generate with: `openssl rand -base64 32`"
      },
      "DB": {
        "description": "D1 database for FlareAuth identity data"
      },
      "ASSET_BUCKET": {
        "description": "R2 bucket for uploaded avatars, organization logos, and application logos"
      },
      "EMAIL": {
        "description": "Cloudflare Email Routing send_email binding"
      },
      "EMAIL_QUEUE": {
        "description": "Queue producer reserved for async email delivery and retries"
      }
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,jsonc}": "biome check --write --no-errors-on-unmatched"
  },
  "volta": {
    "node": "24.14.1",
    "npm": "11.11.0"
  },
  "overrides": {
    "esbuild": "^0.27.3"
  }
}
