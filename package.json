{
  "name": "flareauth",
  "version": "0.0.1",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "[ \"$WORKERS_CI\" = \"1\" ] && [ \"$WORKERS_CI_BRANCH\" != \"main\" ] && export CF_WRANGLER_CONFIG=wrangler.preview.toml; vite build",
    "deploy": "npm run deploy:prod",
    "deploy:prod": "npm run db:migrate:prod && npm run build && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply flareauth-db --local",
    "db:migrate:staging": "wrangler d1 migrations apply flareauth-db-staging --remote --config wrangler.preview.toml",
    "db:migrate:prod": "wrangler d1 migrations apply flareauth-db --remote",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "^1.93.0",
    "better-auth": "^1.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@cloudflare/vite-plugin": "^1.36.3",
    "@cloudflare/vitest-pool-workers": "^0.16.3",
    "@cloudflare/workers-types": "^4.20260510.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^17.0.4",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.2",
    "wrangler": "^4.90.0"
  },
  "cloudflare": {
    "bindings": {
      "BETTER_AUTH_SECRET": {
        "description": "Signing secret for auth sessions. Generate with: `openssl rand -base64 32`"
      },
      "DB": {
        "description": "D1 database for FlareAuth identity data"
      }
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,jsonc}": "biome check --write --no-errors-on-unmatched"
  },
  "volta": {
    "node": "24.14.1",
    "npm": "11.11.0"
  },
  "overrides": {
    "esbuild": "^0.27.3"
  }
}
